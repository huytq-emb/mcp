{
  "name": "local-renesas-manual-mcp-server",
  "version": "1.0.0",
  "description": "Local MCP server for extracting Linux-driver evidence from Renesas hardware manuals.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "health": "npm run check && npm run static-health && npm run architecture-health && npm run python:health && npm run startup-smoke",
    "smoke": "npm run startup-smoke && npm run test:eval",
    "test": "npm run health && npm run test:unit && npm run test:python && npm run test:eval && npm run test:profiles && npm run test:golden",
    "check": "node --check index.js",
    "static-health": "node scripts/static-health.js",
    "architecture-health": "node scripts/architecture-health.js",
    "startup-smoke": "node scripts/startup-smoke.js",
    "test:unit": "node --test \"test/unit/*.test.js\"",
    "test:eval": "node scripts/eval-smoke.js",
    "test:profiles": "node scripts/profile-eval-smoke.js",
    "golden:bootstrap": "node scripts/golden-bootstrap.js",
    "golden:seed-report": "node scripts/golden-seed-report.js",
    "golden:eval": "node scripts/golden-eval.js",
    "test:golden": "node scripts/golden-eval.js --no-write",
    "test:tools": "node scripts/tool-smoke-rzg3e.js --filename=r01uh1069ej0115-rzg3e.pdf",
    "python:setup": "node scripts/python-setup.js",
    "python:health": "node scripts/python-health.js",
    "ocr:prewarm": "node scripts/ocr-prewarm.js",
    "test:python": "node scripts/python-test.js",
    "test:hybrid": "node --test test/unit/python-worker.test.js && node scripts/python-test.js",
    "benchmark:extraction": "node scripts/benchmark-extraction.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284"
  }
}
