{
  "schemaVersion": 1,
  "type": "eval-profile",
  "profile": "rtc",
  "description": "rtc eval cases for hardware-manual driver workflow smoke tests.",
  "when": {
    "module_type": "rtc"
  },
  "cases": [
    {
      "id": "profile-rtc-workflow",
      "tool": "plan_manual_workflow",
      "args": {
        "task": "rtc driver completeness review",
        "module_type": "rtc",
        "source_files": [
          "<driver>.c"
        ]
      },
      "assertions": {
        "mustContain": [
          "Manual Workflow Plan",
          "Recommended MCP call sequence",
          "verify_register_usage"
        ],
        "mustNotContain": [
          "Unhandled",
          "TypeError",
          "ReferenceError"
        ]
      }
    },
    {
      "id": "profile-rtc-search",
      "tool": "hybrid_search_pdf",
      "args": {
        "query": "RTC time alarm counter clock status clear",
        "intent": "driver evidence",
        "top_k": 6
      },
      "assertions": {
        "mustContain": [
          "Hybrid search results"
        ],
        "mustContainAny": [
          "RTC",
          "time",
          "alarm",
          "counter",
          "Result 1"
        ],
        "mustNotContain": [
          "Unhandled",
          "TypeError",
          "ReferenceError"
        ]
      },
      "allowFail": true
    }
  ]
}
