{
  "schemaVersion": 1,
  "type": "eval-profile",
  "profile": "pinctrl",
  "description": "pinctrl eval cases for hardware-manual driver workflow smoke tests.",
  "when": {
    "module_type": "pinctrl"
  },
  "cases": [
    {
      "id": "profile-pinctrl-workflow",
      "tool": "plan_manual_workflow",
      "args": {
        "task": "pinctrl driver completeness review",
        "module_type": "pinctrl",
        "source_files": [
          "<driver>.c"
        ]
      },
      "assertions": {
        "mustContain": [
          "Manual Workflow Plan",
          "Recommended MCP call sequence",
          "verify_register_usage"
        ],
        "mustNotContain": [
          "Unhandled",
          "TypeError",
          "ReferenceError"
        ]
      }
    },
    {
      "id": "profile-pinctrl-search",
      "tool": "hybrid_search_pdf",
      "args": {
        "query": "pin function mux register table drive pull",
        "intent": "driver evidence",
        "top_k": 6
      },
      "assertions": {
        "mustContain": [
          "Hybrid search results"
        ],
        "mustContainAny": [
          "pin",
          "function",
          "mux",
          "register",
          "Result 1"
        ],
        "mustNotContain": [
          "Unhandled",
          "TypeError",
          "ReferenceError"
        ]
      },
      "allowFail": true
    }
  ]
}
